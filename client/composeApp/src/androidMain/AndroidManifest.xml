<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Авто-обновление: установка скачанного APK системным установщиком -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <!-- Звонки/аудио-чаты (LiveKit/WebRTC): микрофон, камера, маршрутизация звука -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <!-- Вибрация на входящий звонок -->
    <uses-permission android:name="android.permission.VIBRATE" />
    <!-- Звонок продолжается при погашенном экране: без foreground-сервиса Android
         отбирает микрофон и камеру у фонового приложения, и звук пропадает -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CAMERA" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Своя доставка вместо пушей Google: держим WS-соединение в фоне и после ребута -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Разбудить экран на входящий звонок -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <!-- Просим исключить из оптимизации батареи: иначе система усыпит соединение -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <!-- Телефонная книга: найти контакты, зарегистрированные в TIMA -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.microphone" android:required="false" />

    <!-- usesCleartextTraffic: dev-сервер на http://; прод пойдёт через Caddy по TLS -->
    <application
        android:label="TIMA"
        android:usesCleartextTraffic="true"
        android:theme="@android:style/Theme.Material.Light.NoActionBar">

        <!-- FileProvider: отдаём скачанный APK установщику как content:// (file:// запрещён с Android 7) -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.updates"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
        <!-- Держит звонок живым, пока экран погашен или приложение свёрнуто -->
        <service
            android:name=".platform.CallService"
            android:exported="false"
            android:foregroundServiceType="microphone|camera" />
        <!-- Наша замена пушам: держит WS-соединение, пока приложение свёрнуто.
             dataSync — соединение с нашим сервером, никакого Google. -->
        <service
            android:name=".platform.TimaService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />
        <!-- Поднять сервис после перезагрузки телефона -->
        <receiver
            android:name=".platform.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
        <!-- adjustResize: окно ужимается под клавиатуру, чат не «уезжает» вверх -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
