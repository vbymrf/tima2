# ШАБЛОН секретов боевого стека TIMA. Скопируй в deploy/.env и заполни.
#   cp deploy/.env.example deploy/.env && chmod 600 deploy/.env
# Файл deploy/.env В GIT НЕ ПОПАДАЕТ (см. .gitignore). Каждое <...> — сгенерируй командой рядом.

# Домен (без поддоменов). Нужны A-записи api.  s3.  lk.  → IP VPS
DOMAIN=example.com

# PostgreSQL
POSTGRES_USER=tima
POSTGRES_PASSWORD=<openssl rand -hex 24>
POSTGRES_DB=tima

# Redis
REDIS_PASSWORD=<openssl rand -hex 24>

# MinIO (объектное хранилище медиа)
MINIO_ROOT_USER=tima-admin
MINIO_ROOT_PASSWORD=<openssl rand -hex 24>

# Подпись JWT сессий. При смене — ВСЕ активные сессии инвалидируются (нужен повторный вход)
JWT_SIGNING_KEY=<openssl rand -hex 32>

# LiveKit (звонки). Эти ЖЕ значения впиши в deploy/livekit/livekit.yaml (секция keys)
LIVEKIT_API_KEY=<openssl rand -hex 16>
LIVEKIT_API_SECRET=<openssl rand -hex 32>

# SMS. 1 = код возвращается в ответе (для теста без провайдера), 0 = боевой режим.
# ОБЯЗАТЕЛЬНО верни 0 перед реальными пользователями.
TIMA_DEV_SMS=1
