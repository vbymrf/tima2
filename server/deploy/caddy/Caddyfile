# Caddy edge для TIMA (ADR-0008). TLS-сертификаты — Let's Encrypt автоматически,
# продление тоже. {$DOMAIN} подставляется из окружения (см. docker-compose.prod.yml).
#
# Поддомены (все A-записи → IP VPS):
#   api.DOMAIN — REST + WebSocket (/ws)
#   s3.DOMAIN  — MinIO (клиенты ходят по presigned URL напрямую)
#   lk.DOMAIN  — LiveKit signaling (звонки/аудио-чаты)

api.{$DOMAIN} {
	encode zstd gzip
	# Раздача APK для авто-обновления приложения (файлы из deploy/download/)
	handle_path /download/* {
		root * /srv/download
		file_server
	}
	# Всё остальное — на бэкенд: REST /api/*, WebSocket /ws, /healthz
	handle {
		reverse_proxy backend:8080
	}
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		-Server
	}
}

s3.{$DOMAIN} {
	# presigned PUT/GET клиентов; подпись содержит хост — снаружи это s3.DOMAIN
	reverse_proxy minio:9000
	request_body {
		max_size 2GB
	}
}

lk.{$DOMAIN} {
	# LiveKit слушает 7880 на host network — тянемся через host-gateway
	reverse_proxy host.docker.internal:7880
}
